import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		// your code goes here
		Scanner sc = new Scanner(System.in);
		
		int t = sc.nextInt();
		
		while(t-- > 0){
		    int n = sc.nextInt();
		    int totalIncome = n*50;
		    
		    double totalExp = totalIncome*0.2 + totalIncome*0.2 + totalIncome*0.3;
		    
		    System.out.println((int)(totalIncome - totalExp));
		}

	}
}
