class Solution {
    public int findCenter(int[][] edges) {
        int first = edges[0][0];
        int second = edges[0][1];

        int ans = -1;

        for(int i = 1; i<edges.length; i++){
            if(edges[i][0] == first || edges[i][1] == first){
                ans = first;
            }else if(edges[i][0] == second || edges[i][1] == second){
                ans = second;
            }
        }

        return ans;
    }
}
