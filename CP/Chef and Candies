import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		// your code goes here
		Scanner sc = new Scanner(System.in);
		
		int t = sc.nextInt();
		
		while(t-- > 0){
		    int n = sc.nextInt();
		    int x = sc.nextInt();
		    
		    if(n > x){
		        int reqPacket = (int)Math.ceil((n-x)/4.0);
		        System.out.println(reqPacket);
		    }else{
		        System.out.println("0");
		    }
		}

	}
}
