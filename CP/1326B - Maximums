import java.util.*;
import java.lang.*;
import java.io.*;

public class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		// your code goes here
		Scanner sc = new Scanner(System.in);
		
		int n = sc.nextInt();
		
		Long arr[] = new Long[n];
		Long max = 0L;
		
		for(int i = 0; i<n; i++){
		    long val = sc.nextLong();
		    arr[i] = val + max;
		    max = Math.max(max,arr[i]);
		}
		
		for(int i = 0; i<n; i++){
		    System.out.print(arr[i] + " ");
		}

	}
}
